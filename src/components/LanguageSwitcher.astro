---
import { getLangFromUrl } from '../i18n';

const currentLang = getLangFromUrl(Astro.url);
---

<button
  id="lang-toggle"
  class="icon-btn-toggle icon-btn-toggle-ghost"
  data-lang={currentLang}
  aria-label="Change language"
  title="Korean ↔ English"
>
  <div class="icon-btn-toggle-icon">
    <span class="lang-text">{currentLang.toUpperCase()}</span>
  </div>
</button>

<style>
  .lang-text {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    color: var(--theme-text-secondary);
    transition: color 0.2s ease;
  }

  #lang-toggle:hover .lang-text {
    color: var(--theme-accent);
  }
</style>

<script>
  function initLanguageSwitcher() {
    const langBtn = document.getElementById('lang-toggle');
    if (!langBtn) return;

    // Simple toggle between KO and EN
    langBtn.addEventListener('click', () => {
      const currentLang = langBtn.getAttribute('data-lang') || 'ko';
      const newLang = currentLang === 'ko' ? 'en' : 'ko';

      // Store preference
      localStorage.setItem('preferred-language', newLang);

      // Update button
      langBtn.setAttribute('data-lang', newLang);
      const langText = langBtn.querySelector('.lang-text');
      if (langText) {
        langText.textContent = newLang.toUpperCase();
      }

      // Update document lang attribute
      document.documentElement.setAttribute('lang', newLang);

      // TODO: Implement actual language switching when multi-language routing is added
      console.log(`Language switched to: ${newLang}`);
    });

    // Load preferred language on page load
    const preferredLang = localStorage.getItem('preferred-language') || 'ko';
    document.documentElement.setAttribute('lang', preferredLang);
    langBtn.setAttribute('data-lang', preferredLang);
    const langText = langBtn.querySelector('.lang-text');
    if (langText) {
      langText.textContent = preferredLang.toUpperCase();
    }
  }

  // Initialize on page load
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initLanguageSwitcher);
  } else {
    initLanguageSwitcher();
  }

  // Reinitialize after page navigation (for view transitions)
  document.addEventListener('astro:after-swap', initLanguageSwitcher);
</script>
