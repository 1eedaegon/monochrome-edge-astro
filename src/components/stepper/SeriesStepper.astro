---
interface Step {
  indicator: string;
  labelTitle: string;
  labelDesc: string;
  title: string;
  desc: string;
  state: 'pending' | 'active' | 'completed';
  href: string;
}

interface Props {
  steps: Step[];
  id?: string;
  layout?: 'horizontal' | 'vertical' | 'snake';
  type?: 'default' | 'text';
}

const {
  steps,
  id = 'stepper',
  layout = 'snake',
  type = 'default'
} = Astro.props;
---

<link rel="stylesheet" href={`${import.meta.env.BASE_URL}vendor/stepper/stepper-unified.css`} />

<div
  class="stepper"
  id={id}
  data-type={type}
  data-layout={layout}
  data-steps={JSON.stringify(steps)}
>
</div>

<script define:vars={{ stepperId: id, basePath: import.meta.env.BASE_URL }}>
  (function() {
    function initStepper() {
      const stepperEl = document.getElementById(stepperId);
      if (!stepperEl) return;
      if (stepperEl.classList.contains('stepper-initialized')) return;

      function createStepper() {
        new window.MonochromeEdge.Stepper(stepperEl, {
          onStepClick: (step) => {
            if (step.href) {
              window.location.href = step.href;
            }
          }
        });
        stepperEl.classList.add('stepper-initialized');
      }

      if (window.MonochromeEdge && window.MonochromeEdge.Stepper) {
        createStepper();
        return;
      }

      // Try loading from local vendor, then CDN fallbacks
      const paths = [
        `${basePath}vendor/stepper/stepper.js`,
        'https://cdn.jsdelivr.net/npm/@monochrome-edge/ui@latest/components/stepper/stepper.js',
        'https://cdn.jsdelivr.net/npm/@monochrome-edge/ui/dist/components/stepper/stepper.js'
      ];

      let pathIndex = 0;

      function tryLoadScript() {
        if (pathIndex >= paths.length) return;

        const script = document.createElement('script');
        script.src = paths[pathIndex];

        script.onerror = () => {
          pathIndex++;
          tryLoadScript();
        };

        script.onload = () => {
          if (window.MonochromeEdge && window.MonochromeEdge.Stepper) {
            createStepper();
          }
        };

        document.head.appendChild(script);
      }

      tryLoadScript();
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initStepper);
    } else {
      initStepper();
    }

    document.addEventListener('astro:after-swap', initStepper);
  })();
</script>
