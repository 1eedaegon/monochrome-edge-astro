---
import { getEntry, render } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const page = await getEntry('pages', 'code-work');
if (!page) throw new Error('Code work page not found');
const rendered = await render(page);
const Content = rendered.Content;
---

<BaseLayout title={page.data.title} description={page.data.description}>
  <Header />
  <main class="container">
    <article class="prose">
      <Content />
    </article>
  </main>
  <Footer />
</BaseLayout>

<style>
  .prose {
    max-width: 900px;
    margin: 0 auto;
    padding: 3rem 0;
    color: var(--theme-text-primary);
  }

  .prose :global(h2) {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--theme-text-primary);
    margin-top: 3rem;
    margin-bottom: 1rem;
  }

  .prose :global(h2:first-of-type) {
    margin-top: 0;
  }

  .prose :global(h3) {
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--theme-text-primary);
    margin-top: 2rem;
    margin-bottom: 1rem;
  }

  .prose :global(h4) {
    font-size: 1.0625rem;
    font-weight: 600;
    color: var(--theme-text-primary);
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
  }

  .prose :global(h2 a),
  .prose :global(h3 a),
  .prose :global(h4 a) {
    color: inherit;
    text-decoration: none;
  }

  .prose :global(h2 a:hover),
  .prose :global(h3 a:hover),
  .prose :global(h4 a:hover) {
    color: var(--theme-accent);
  }

  .prose :global(p) {
    line-height: 1.8;
    margin-bottom: 1rem;
    color: var(--theme-text-secondary);
  }

  .prose :global(strong) {
    font-weight: 600;
    color: var(--theme-text-primary);
  }

  .prose :global(a) {
    color: var(--theme-accent);
    text-decoration: none;
    transition: color var(--transition-speed);
  }

  .prose :global(a:hover) {
    color: var(--theme-highlight);
  }

  .prose :global(ul) {
    list-style: none;
    padding-left: 0;
    margin-bottom: 1rem;
  }

  .prose :global(li) {
    margin-bottom: 0.5rem;
    line-height: 1.6;
  }

  .prose :global(code) {
    font-family: var(--font-family-mono);
    font-size: 0.875rem;
    background-color: var(--theme-surface);
    padding: 0.2em 0.4em;
    border-radius: calc(var(--border-radius) / 2);
    border: 1px solid var(--theme-border);
    color: var(--theme-text-primary);
  }

  .prose :global(pre) {
    background-color: var(--theme-surface);
    border: 1px solid var(--theme-border);
    padding: 1rem;
    border-radius: var(--border-radius);
    overflow-x: auto;
    margin: 1.5rem 0;
  }

  .prose :global(pre code) {
    background: none;
    border: none;
    padding: 0;
    font-size: 0.875rem;
  }

  @media (max-width: 768px) {
    .prose {
      padding: 2rem 0;
    }

    .prose :global(h2:first-of-type) {
      font-size: 2rem;
    }

    .prose :global(h2) {
      font-size: 1.25rem;
      margin-top: 2rem;
    }

    .prose :global(h3) {
      font-size: 1.125rem;
    }

    .prose :global(h4) {
      font-size: 1rem;
    }
  }
</style>
