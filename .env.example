# Site Configuration
# Copy this file to .env and update with your values

# Site Information
SITE_NAME=My Tech Blog
SITE_TITLE=My Tech Blog
SITE_DESCRIPTION=A minimal, elegant technical blog built with Astro and Monochrome Edge UI
SITE_URL=https://username.github.io
SITE_AUTHOR=Your Name

# Social Links
GITHUB_USERNAME=username
TWITTER_USERNAME=username
EMAIL=your.email@example.com

# Analytics (optional)
# GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX

# Comments (optional - Giscus)
# Get these values from https://giscus.app
# GISCUS_ENABLED=true
# GISCUS_REPO=username/repo
# GISCUS_REPO_ID=R_xxxxx
# GISCUS_CATEGORY=Announcements
# GISCUS_CATEGORY_ID=DIC_xxxxx

# Theme Settings (optional - defaults are set in config.ts)
# DEFAULT_THEME=warm
# DEFAULT_MODE=auto
